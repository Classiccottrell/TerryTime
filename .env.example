# Copy to .env.local and fill in. None of these are required to run the site —
# without them, checkout and signup degrade to clear "not live yet" messages.

# Public base URL (used for Stripe success/cancel redirects). Optional in dev —
# the request origin is used as a fallback.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Stripe (shop checkout) ----
# Secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# Signing secret for the /api/webhook endpoint (Stripe Dashboard → Webhooks,
# or `stripe listen` for local dev).
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- Newsletter (community signup) ----
# Option A — Resend audiences (https://resend.com/audiences)
RESEND_API_KEY=re_xxx
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Option B — any provider via a webhook (Buttondown / ConvertKit / Zapier /
# Mailchimp). Receives { "email": "..." }. Used only if Resend isn't set.
# NEWSLETTER_WEBHOOK_URL=https://example.com/hook

# ---- Fulfilment (optional, for the webhook TODO) ----
# PRINTFUL_API_KEY=your_printful_store_api_key
